/* -------------------------- 所有列表容器 -------------------------- */
.all-list-div {
  padding: 0 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
/* -------------------------- 通用模块样式 - 美团卡片 -------------------------- */
.mt-section {
  background-color: var(--mt-white);
  border-radius: var(--mt-radius);
  box-shadow: var(--mt-shadow);
  overflow: hidden;
}
.mt-section-title {
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid var(--mt-gray-4);
}
.mt-title-text {
  font-size: 28rpx;
  color: var(--mt-gray-1);
  font-weight: 600;
}
/* -------------------------- 商品列表 - 一行两个布局 -------------------------- */
.mt-merchant-list {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
  gap: 16rpx;
}
.mt-merchant-list navigator {
  text-decoration: none;
  color: inherit;
  width: calc(50% - 8rpx);
}
.mt-merchant-card {
  border-radius: 12rpx;
  overflow: hidden;
  background-color: var(--mt-gray-4);
  transition: all 0.2s ease;
}
.mt-merchant-card:active {
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}
.mt-merchant-img {
  width: 100%;
  height: 180rpx;
  object-fit: cover;
}
.mt-merchant-info {
  padding: 12rpx;
  background-color: var(--mt-white);
}
.mt-merchant-name {
  font-size: 26rpx;
  color: var(--mt-gray-1);
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.mt-merchant-tag {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}
.mt-tag-sep {
  font-size: 20rpx;
  color: var(--mt-gray-4);
  margin: 0 8rpx;
}
.mt-tag-sale {
  font-size: 24rpx;
  color: var(--mt-gray-3);
}
.mt-merchant-price {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}
.mt-price {
  font-size: 28rpx;
  color: var(--mt-orange);
  font-weight: 600;
}
.mt-freight {
  font-size: 22rpx;
  color: var(--mt-gray-3);
  margin-left: 8rpx;
}
.mt-merchant-desc {
  display: flex;
  justify-content: flex-start;
}
.mt-desc-tag {
  font-size: 22rpx;
  color: var(--mt-gray-3);
  background-color: var(--mt-gray-4);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}
/* -------------------------- 帖子/公告列表 -------------------------- */
.mt-notice-section {
  padding-bottom: 8rpx;
}
.mt-notice-list {
  padding: 8rpx 0;
}
.mt-notice-list navigator {
  display: block;
  text-decoration: none;
  color: inherit;
  border-bottom: 1rpx solid var(--mt-gray-4);
}
.mt-notice-list navigator:last-child {
  border-bottom: none;
}
.mt-notice-card {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  gap: 16rpx;
  transition: all 0.2s ease;
}
.mt-notice-card:active {
  background-color: var(--mt-gray-4);
}
.mt-notice-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  object-fit: cover;
}
.mt-notice-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.mt-notice-title {
  font-size: 26rpx;
  color: var(--mt-gray-1);
  font-weight: 500;
}
.mt-notice-subtitle {
  font-size: 24rpx;
  color: var(--mt-gray-2);
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.mt-notice-time {
  font-size: 22rpx;
  color: var(--mt-gray-3);
  display: block;
}
/* -------------------------- 空数据样式 -------------------------- */
.mt-empty {
  padding: 80rpx 0;
  text-align: center;
  background-color: var(--mt-white);
  border-radius: var(--mt-radius);
  margin: 0 16rpx;
}
.mt-empty-text {
  font-size: 28rpx;
  color: var(--mt-gray-3);
}
/* -------------------------- 通用修复 -------------------------- */
navigator {
  text-decoration: none !important;
  color: inherit !important;
}
/* 商品图片循环渲染修复 */
.mt-merchant-card view:first-child {
  width: 100%;
  height: 180rpx;
  overflow: hidden;
}
.mt-merchant-card view:first-child image {
  width: 100%;
  height: 100%;
}
/* 帖子图片循环渲染修复 */
.mt-notice-card view:first-child {
  width: 100rpx;
  overflow: hidden;
  flex-shrink: 0;
}
.mt-notice-card view:first-child image {
  width: 100%;
}
/* 仿美团搜索框外层容器 */
.mt-search-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  background-color: var(--mt-white);
  margin: 0 16rpx 16rpx;
  border-radius: var(--mt-radius);
  box-shadow: var(--mt-shadow);
}
/* 搜索输入容器（核心：美团经典搜索框样式） */
.mt-search-input-box {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: var(--mt-gray-4);
  border-radius: 60rpx; /* 美团圆角搜索框 */
  padding: 0 20rpx;
  height: 72rpx;
  box-sizing: border-box;
}
/* 搜索图标（美团风格） */
.mt-search-icon {
  font-size: 28rpx;
  color: var(--mt-gray-3);
  margin-right: 12rpx;
  line-height: 1;
}
/* 搜索输入框 */
.mt-search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: var(--mt-gray-1);
  background: transparent;
  border: none;
  outline: none;
  /* 清除小程序默认样式 */
  padding: 0;
  margin: 0;
}
/* 占位符样式（美团浅灰色） */
.mt-search-placeholder {
  font-size: 26rpx;
  color: var(--mt-gray-3);
}
/* 右侧取消按钮（美团风格） */
.mt-search-btn {
  font-size: 28rpx;
  color: var(--mt-gray-1);
  margin-left: 16rpx;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  transition: all 0.2s ease;
}
/* 按钮点击态（美团交互风格） */
.mt-search-btn:active {
  background-color: var(--mt-gray-4);
  color: var(--mt-orange);
}
/* 适配输入框获取焦点样式 */
.mt-search-input-box:focus-within {
  background-color: #fafafa;
  box-shadow: 0 0 0 2rpx rgba(255, 125, 0, 0.1); /* 美团橙浅边框 */
}

/* 筛选功能根容器：隔离全局样式 */
.filter_page_container {
  width: 100%;
  box-sizing: border-box;
}
/* 顶部筛选Tab外层：加长类名 */
.filter_top_tab_wrap {
  display: flex;
  background: #fff;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
/* 顶部Tab项：加长类名 */
.filter_tab_item {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  position: relative;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}
/* Tab选中态：加长类名+!important，避免被覆盖 */
.filter_tab_active {
  color: #E53935 !important;
  font-weight: 600 !important;
}
/* 角标数字：加长类名 */
.filter_badge_num {
  position: absolute;
  top: 10rpx;
  right: 30rpx;
  width: 30rpx;
  height: 30rpx;
  line-height: 30rpx;
  background: #E53935;
  color: #fff;
  font-size: 20rpx;
  border-radius: 50%;
  text-align: center;
}
/* 筛选弹窗外层：加长类名+提高层级 */
.filter_modal_wrap {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: none;
  z-index: 9999; /* 避免被其他组件遮挡 */
}
/* 弹窗显示状态：加长类名 */
.filter_modal_show {
  display: block;
}
/* 弹窗遮罩层：加长类名 */
.filter_modal_mask {
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
}
/* 弹窗内容区：加长类名 */
.filter_modal_content_box {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 20rpx;
  max-height: 90vh;
  box-sizing: border-box;
}
/* 弹窗内Tab外层：加长类名 */
.filter_inner_tab_wrap {
  display: flex;
  margin-bottom: 20rpx;
  overflow-x: auto;
  white-space: nowrap;
}
/* 弹窗内Tab项：加长类名 */
.filter_inner_tab_item {
  padding: 0 20rpx;
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  background: #FFF5F5;
  border-radius: 10rpx;
  margin: 0 5rpx;
  font-size: 26rpx;
  white-space: nowrap;
  flex-shrink: 0; /* 防止压缩 */
}
/* 弹窗内Tab选中态：加长类名+!important */
.filter_inner_tab_active {
  background: #E53935 !important;
  color: #fff !important;
}
/* 筛选标签列表外层：新增，优化布局 */
.filter_tag_list_wrap {
  width: 100%;
  box-sizing: border-box;
}
/* 筛选标签项：加长类名+强化样式 */
.filter_tag_item {
  display: inline-block;
  padding: 15rpx 30rpx;
  background: #FFF5F5;
  border: 1rpx solid #FCE4E4;
  border-radius: 20rpx;
  margin: 10rpx;
  font-size: 26rpx;
  color: #333;
  /* 确保点击和样式优先级 */
  position: relative;
  z-index: 1;
  touch-action: manipulation;
  user-select: none;
  pointer-events: auto;
}
/* 标签选中态：加长类名+!important，确保不冲突 */
.filter_tag_active {
  background: #E53935 !important;
  color: #fff !important;
  border-color: #E53935 !important;
}
/* 按钮区外层：加长类名 */
.filter_btn_wrap {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  width: 100%;
  box-sizing: border-box;
}
/* 重置按钮：加长类名 */
.filter_reset_btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #E53935;
  border: 1rpx solid #FCE4E4;
  background: #fff;
}
/* 确认按钮：加长类名+!important */
.filter_confirm_btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  background: #E53935 !important;
  color: #fff !important;
  border: none !important;
}






/* 全局基础样式 - 美团核心风格 */
page {
  background-color: #f5f5f5;
  font-family: "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  --mt-yellow: #FFD100;      /* 美团经典黄 */
  --mt-orange: #FF7D00;      /* 美团橙 */
  --mt-blue: #4A90E2;        /* 轮播指示器蓝 */
  --mt-gray-1: #333333;      /* 主文字 */
  --mt-gray-2: #666666;      /* 次文字 */
  --mt-gray-3: #999999;      /* 淡文字 */
  --mt-gray-4: #f0f0f0;      /* 背景灰 */
  --mt-white: #ffffff;       /* 白色 */
  --mt-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08); /* 卡片阴影 */
  --mt-radius: 16rpx;        /* 通用圆角 */
}
/* 根容器 */
.mt-home {
  width: 100%;
  min-height: 100vh;
}
/* -------------------------- 轮播图样式 - 保留原有优化后样式 -------------------------- */
.swiper-container {
  position: relative;
  background-color: var(--mt-white);
  margin-bottom: 16rpx;
  width: 100%;
  height: 400rpx;
  overflow: hidden;
  border-radius: 16rpx;
}
.swiper {
  width: 100%;
  height: 100%;
}
.swiper-item {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
}
.swiper-img {
  width: 100% !important;
  height: 100%;
  object-fit: cover;
  border-radius: 12rpx;
  transform: scale(1);
  opacity: 1;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}
/* 轮播标题 */
.swiper-title-box {
  position: absolute;
  bottom: 20rpx;
  left: 0;
  width: 100%;
  padding: 8rpx 20rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
}
.swiper-main-title {
  font-size: 28rpx;
  color: var(--mt-white);
  font-weight: 500;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}
/* 轮播控制按钮 */
.swiper-control {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  transform: translateY(-50%);
  display: flex;
  justify-content: space-between;
  padding: 0 16rpx;
  z-index: 10;
  pointer-events: none;
}
.control-btn {
  pointer-events: auto;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: rgba(0,0,0,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  background-color: rgba(255, 255, 255, 0.85);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}
.control-btn text {
  font-size: 24rpx;
  color: var(--mt-white);
  font-size: 36rpx;
  color: #333333;
}
.control-btn:active {
  background-color: rgba(255, 255, 255, 1);
  transform: scale(0.95);
}
.left-btn {
  left: 16rpx;
  margin-left: 10rpx;
}
.right-btn {
  right: 16rpx;
  margin-right: 10rpx;
}
/* -------------------------- 功能入口网格 - 20组中性Emoji+背景色（循环） -------------------------- */
.mt-function-grid {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: var(--mt-white);
  padding: 20rpx 0;
  margin: 0 16rpx 16rpx;
  border-radius: var(--mt-radius);
  box-shadow: var(--mt-shadow);
  flex-wrap: wrap; /* 适配20个图标，自动换行 */
  gap: 20rpx 0; /* 行间距 */
}
/* 修复navigator默认样式（适配20个图标） */
.mt-function-grid navigator {
  text-decoration: none;
  color: inherit;
  width: 20%; /* 一行5个，20个分4行 */
  box-sizing: border-box;
  padding: 0 8rpx;
}
.mt-function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 0;
  transition: all 0.2s ease;
}
/* 按钮点击效果 */
.mt-function-item:active {
  transform: scale(0.96);
  opacity: 0.9;
}
/* 功能图标基础样式（伪元素插入Emoji） */
.mt-function-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 3rpx 9rpx rgba(0, 0, 0, 0.1);
  position: relative; /* 伪元素定位基准 */
}
/* 伪元素通用样式（插入Emoji） */
.mt-function-icon::before {
  content: ""; /* 由nth-child覆盖 */
  font-size: 32rpx;
  color: var(--mt-white);
  line-height: 1;
}
.mt-function-name {
  font-size: 24rpx;
  color: var(--mt-gray-1);
  font-weight: 500;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
}
/* -------------------------- 20组中性渐变背景 + 中性Emoji（循环逻辑） -------------------------- */
/* 第1/21/41...个图标 - 浅蓝渐变 + 放大镜 */
.mt-function-grid navigator:nth-child(20n+1) .mt-function-icon {
  background: linear-gradient(135deg, #E0F7FA, #B2EBF2);
}
.mt-function-grid navigator:nth-child(20n+1) .mt-function-icon::before {
  content: "🔍";
  color: #00ACC1;
}

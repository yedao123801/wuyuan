<view class="page">
	<!-- 主体内容区（全新布局） -->
	<view class="page__bd">
		<!-- 表单外层容器（全新：渐变背景+双层阴影） -->
		<view class="form-container">
			<!-- 表单内层卡片（全新：极简样式） -->
			<view class="form-card">
				<view class="form-card__title">信息编辑</view>
				<!-- 表单项（全新：独立卡片样式） -->
				<view class="edit-form-item">
					<view class="form-label-wrap">
						<view class="form-label">评价星级</view>
					</view>
					<view class="form-content-wrap">
						<view class="star-group">
							<!-- 5颗文本星星，逐个绑定点击 -->
							<text class="star {{evalStar >= 1 ? 'active' : ''}}" bindtap="chooseStar"  data-id="evalStar"  data-score="1">★</text>
							<text class="star {{evalStar >= 2 ? 'active' : ''}}" bindtap="chooseStar"   data-id="evalStar" data-score="2">★</text>
							<text class="star {{evalStar >= 3 ? 'active' : ''}}" bindtap="chooseStar"   data-id="evalStar" data-score="3">★</text>
							<text class="star {{evalStar >= 4 ? 'active' : ''}}" bindtap="chooseStar"  data-id="evalStar" data-score="4">★</text>
							<text class="star {{evalStar >= 5 ? 'active' : ''}}" bindtap="chooseStar"   data-id="evalStar" data-score="5">★</text>
						</view>
					</view>
				</view>
				<!-- 表单项（全新：独立卡片样式） -->
				<view class="edit-form-item">
					<view class="form-label-wrap">
						<view class="form-label">评价内容</view>
					</view>
					<view class="form-content-wrap">
						<input  id="evalContent"  bind:change="inputHandler" value="{{evalContent}}" class="form-input"   placeholder="请输入评价内容"   />
					</view>
				</view>
			</view>
		</view>
	</view>
	<!-- 底部按钮区（全新布局） -->
	<view class="page__ft">
		<button block type="primary" bindtap="submitData" class="submit-btn">提交信息</button>
	</view>
</view>

	border-radius: 16rpx;
	background: linear-gradient(135deg, #e63946 0%, #ff7f50 100%);
	color: #fff;
	font-size: 20rpx;
	font-weight: 600;
	padding: 0 8rpx;
	box-shadow: 0 2rpx 8rpx rgba(230, 57, 70, 0.2);
	z-index: 10;
}
/* 聊天室新消息提示样式（tip-num-show） */
.tip-num-show {
	position: absolute;
	top: 18rpx;
	right: 20rpx;
	min-width: 36rpx;
	height: 36rpx;
	line-height: 36rpx;
	text-align: center;
	border-radius: 18rpx;
	background: linear-gradient(135deg, #e63946 0%, #ff7f50 100%);
	color: #fff;
	font-size: 22rpx;
	font-weight: 600;
	padding: 0 10rpx;
	box-shadow: 0 3rpx 10rpx rgba(230, 57, 70, 0.25);
	z-index: 10;
}
/* 为包含角标的容器添加相对定位（确保角标定位正确） */
.menu-grid-item {
	position: relative;
}
.menu-list-item {
	position: relative;
}

  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  width: 100%;
  box-sizing: border-box;
}
/* 重置按钮：加长类名 */
.filter_reset_btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 10rpx;

}
/* 筛选标签项：加长类名+强化样式 */
.filter_tag_item {
  display: inline-block;
  padding: 15rpx 30rpx;
  background: #FFF5F5;
  border: 1rpx solid #FCE4E4;
  border-radius: 20rpx;
  margin: 10rpx;
  font-size: 26rpx;
  color: #333;
  /* 确保点击和样式优先级 */
  position: relative;
  z-index: 1;
  touch-action: manipulation;
  user-select: none;
  pointer-events: auto;
}
/* 标签选中态：加长类名+!important，确保不冲突 */
.filter_tag_active {
  background: #E53935 !important;
  color: #fff !important;
  border-color: #E53935 !important;
}
/* 按钮区外层：加长类名 */

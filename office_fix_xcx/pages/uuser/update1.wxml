<view class="page">
	<!-- 主体内容区（全新布局） -->
	<view class="page__bd">
		<!-- 表单外层容器（全新：渐变背景+双层阴影） -->
		<view class="form-container">
			<!-- 表单内层卡片（全新：极简样式） -->
			<view class="form-card">
				<view class="form-card__title">信息编辑</view>
				<!-- 表单项（全新：独立卡片样式） -->
				<view class="edit-form-item">
					<view class="form-label-wrap">
						<view class="form-label">姓名</view>
					</view>
					<view class="form-content-wrap">
						<input  id="name"  bind:change="inputHandler" value="{{name}}" class="form-input"   placeholder="请输入姓名"   />
					</view>
				</view>
				<!-- 表单项（全新：独立卡片样式） -->
				<view class="edit-form-item">
					<view class="form-label-wrap">
						<view class="form-label">联系电话</view>
					</view>
					<view class="form-content-wrap">
						<input  id="celphone"  bind:change="inputHandler" value="{{celphone}}" class="form-input"   placeholder="请输入联系电话"   />
					</view>
				</view>
				<!-- 表单项（全新：独立卡片样式） -->
				<view class="edit-form-item">
					<view class="form-label-wrap">
						<view class="form-label">头像</view>
					</view>
					<view class="form-content-wrap">
						<view class="upload-box">
							<!-- 已选文件列表（支持图片/视频/文件/音频） -->
							<view class="file-list">
								<block wx:for="{{headImgFileList}}" wx:key="index">
									<!-- 通用文件项：不同类型展示不同样式 -->
									<view class="file-item">
										<!-- 1. 图片/视频预览 -->
										<view class="media-preview" wx:if="{{item.fileType === 'image' || item.fileType === 'video'}}" bindtap="previewMedia" data-index="{{index}}" data-id="headImg">
											<image class="file-img" src="{{item.coverUrl || item.tempUrl}}" mode="aspectFill"></image>
											<!-- 视频时长 -->
											<view class="video-duration" wx:if="{{item.fileType === 'video'}}">{{item.duration}}</view>
											<!-- 视频/音频图标 -->
											<view class="file-icon {{item.fileType}}" wx:if="{{item.fileType === 'video' || item.fileType === 'audio'}}">
												<text>{{item.fileType === 'video' ? '🎬' : '🎵'}}</text>
											</view>
										</view>
										<!-- 2. 文件/音频预览（文字+图标） -->
										<view class="file-preview" wx:if="{{item.fileType === 'file' || item.fileType === 'audio'}}" bindtap="openFile" data-index="{{index}}" data-id="headImg">
											<view class="file-icon {{item.fileType}}">
												<text>{{item.fileType === 'file' ? '📄' : '🎵'}}</text>
											</view>
											<view class="file-info">
												<view class="file-name">{{item.fileName || '未知文件'}}</view>
												<view class="file-size">{{item.fileSize}}</view>
											</view>
										</view>
										<!-- 删除按钮 -->
										<view class="del-btn" bindtap="delFile" data-id="headImg" data-index="{{index}}">×</view>
										<!-- 上传状态提示 -->
										<view class="upload-status" wx:if="{{item.uploadStatus === 'uploading'}}">上传中...</view>
										<view class="upload-status success" wx:if="{{item.uploadStatus === 'success'}}">✓</view>
										<view class="upload-status fail" wx:if="{{item.uploadStatus === 'fail'}}">×</view>
									</view>
								</block>
							</view>
							<!-- 上传按钮（数量限制） -->
							<view class="upload-btn" wx:if="{{headImgFileList.length < 1}}"
									data-maxnum="1" data-id="headImg" bindtap="chooseUploadType"  data-filetype="1">
									<view class="upload-icon">+</view>
									<view class="upload-text">点击上传文件</view>
								</view>
							</view>
						</view>
					</view>
					<!-- 表单项（全新：独立卡片样式） -->
					<view class="edit-form-item">
						<view class="form-label-wrap">
							<view class="form-label">部门</view>
						</view>
						<view class="form-content-wrap">
							<view class="btn-group">
								<block wx:for="{{departShowList}}" wx:key="id">
									<button class="type-btn {{item.isSelected ? 'type-btn-active' : ''}}" bindtap="toggleSelect" data-iscomplex="2" data-value="{{item.value}}" data-id="depart">
										{{item.title}}
									</button>
								</block>
								<button class="more-btn" bindtap="toggleShow" wx-if="{{departList.length>7}}" data-id="depart">
									{{departShowAll ? '收起' : '《更多'}}
								</button>
							</view>
						</view>
					</view>
				</view>
			</view>
		</view>
		<!-- 底部按钮区（全新布局） -->
		<view class="page__ft">
			<button block type="primary" bindtap="submitData" class="submit-btn">提交信息</button>
		</view>
	</view>

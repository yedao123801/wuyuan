/* ================= 全局重置与基础样式（红色调+优化版） ================= */
page {
  -webkit-overflow-scrolling: touch;
  background: linear-gradient(180deg, #FFF5F5 0%, #FCE4E4 100%);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0;
  margin: 0;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  line-height: 1.5;
  overflow-x: hidden;
}
/* ================= 顶部导航栏（优化版） ================= */
.page__nav {
  height: 112rpx;
  background-color: #FFFFFF;
  box-shadow: 0 4rpx 20rpx rgba(229, 57, 53, 0.06);
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  position: relative;
  z-index: 10;
  border-bottom-left-radius: 24rpx;
  border-bottom-right-radius: 24rpx;
}
.nav__back {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #E53935;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50%;
  transition: all 0.2s ease;
}
.nav__back:active {
  background-color: #FFF0F0;
  transform: scale(0.95);
}
.nav__title {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 36rpx;
  font-weight: 600;
  color: #263238;
  letter-spacing: 1rpx;
}
/* ================= 主体内容区（优化版） ================= */
.page__bd {
  flex: 1;
  padding: 32rpx 24rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  max-width: 750rpx;
  margin: 0 auto;
  width: 100%;
  box-sizing: border-box;
}
/* 表单外层容器（优化：渐变更自然，阴影层次） */
.form-container {
  background: linear-gradient(135deg, #FFFFFF 0%, #FFFBFB 95%);
  border-radius: 40rpx;
  padding: 12rpx;
  box-shadow: 
    0 8rpx 24rpx rgba(229, 57, 53, 0.05),
    0 2rpx 8rpx rgba(229, 57, 53, 0.03);
  box-sizing: border-box;
}
/* 表单内层卡片（优化版） */
.form-card {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  border: 1rpx solid #FCE4E4;
  position: relative;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}
/* 表单卡片角标装饰（优化） */
.form-card::before {
  content: "";
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #E53935 0%, #C62828 100%);
  border-radius: 20rpx;
  opacity: 0.06;
  transform: rotate(15deg);
}
/* 表单标题（优化版） */
.form-card__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #E53935;
  margin-bottom: 36rpx;
  display: flex;
  align-items: center;
  letter-spacing: 0.5rpx;
}
.form-card__title::after {
  content: "";
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, #FCE4E4 0%, transparent 100%);
  margin-left: 20rpx;
  align-self: center;
}
/* ================= 单个表单项（优化版） ================= */
.edit-form-item {
  display: flex;
  flex-direction: column;
  background-color: #FFFBFB;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(229, 57, 53, 0.04);
  border: 1rpx solid #FDE0E0;
  transition: all 0.3s ease;
  box-sizing: border-box;
}
.edit-form-item:last-child {
  margin-bottom: 0;
}
.edit-form-item:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 18rpx rgba(229, 57, 53, 0.08);
  border-color: #F9BABA;
  scale: 1.005;
}
/* ================= 核心优化：表单标签区域（重点修复） ================= */
/* 标签容器 - 彻底重构，更协调的布局 */
.form-label-wrap {
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  /* 新增：标签容器背景，增加层次感 */
  background: linear-gradient(90deg, #FFF0F0 0%, transparent 100%);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  /* 新增：轻微阴影 */
  box-shadow: 0 1rpx 4rpx rgba(229, 57, 53, 0.05);
}
/* 表单标签 - 优化配色和尺寸，更柔和 */
.form-label {
  font-size: 28rpx;
  color: #E53935; /* 改为红色文字，而非红色背景，更协调 */
  font-weight: 600;
  /* 移除红色背景，改为文字配色 */
  padding: 0;
  background: transparent;
  border-radius: 0;
  display: inline-block;
  letter-spacing: 0.5rpx;
  /* 新增：标签前缀装饰 */
  position: relative;
  padding-left: 12rpx;
}
/* 标签前缀小竖线，增加视觉焦点 */
.form-label::before {
  content: "";
  position: absolute;
  left: 0;
  top: 2rpx;
  bottom: 2rpx;
  width: 4rpx;
  background: linear-gradient(180deg, #E53935 0%, #F44336 100%);
  border-radius: 2rpx;
}
/* 必填标识 - 优化样式，融入整体设计 */
.required-tag {
  color: #E53935; /* 改为红色，匹配标签 */
  font-size: 22rpx;
  margin-left: 8rpx;
  font-weight: 700;
  /* 新增：必填标识背景 */
  background: #FFF0F0;
  padding: 2rpx 6rpx;
  border-radius: 4rpx;
}
/* ================= 输入控件（优化版） ================= */
.form-content-wrap {
  width: 100%;
  position: relative;
  box-sizing: border-box;
}
/* 输入框：优化样式，匹配新标签 */
.form-input {
  width: 100% !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  padding: 0 24rpx !important;
  border: 1rpx solid #FCE4E4 !important; /* 匹配主题色 */
  border-radius: 16rpx !important;
  font-size: 30rpx !important;
  color: #111827 !important;
  background-color: #FFFFFF !important;
  box-sizing: border-box !important;
  outline: none !important;
  -webkit-appearance: none !important;
  appearance: none !important;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.02) !important;
  transition: all 0.2s ease-in-out !important;
  caret-color: #E53935 !important; /* 匹配主题色 */
}
.form-input:focus {
  border-color: #E53935 !important; /* 匹配主题色 */
  background-color: #FFFBFB !important;
  box-shadow: 0 0 0 4rpx rgba(229, 57, 53, 0.1) !important;
  transform: translateY(-1rpx) !important;
}
.form-input:disabled {
  border-color: #F3F4F6 !important;
  color: #9CA3AF !important;
  background-color: #F9FAFB !important;
  cursor: not-allowed !important;
  opacity: 0.85 !important;
}
.form-input::placeholder {
  color: #D1D5DB !important;
  font-size: 28rpx !important;
  font-style: normal !important;
  opacity: 0.8 !important;
}
.form-input[type="password"] {
  letter-spacing: 4rpx !important;
}
.form-input:hover:not(:disabled):not(:focus) {
  border-color: #F9BABA !important;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.03) !important;
}
.form-input.error {
  border-color: #EF4444 !important;
  box-shadow: 0 0 0 4rpx rgba(239, 68, 68, 0.1) !important;
}
/* 多行文本框核心样式 - 匹配主题色 */
.form-textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  border: 1rpx solid #FCE4E4 !important; /* 匹配主题色 */
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #1f2937;
  background-color: #ffffff;
  caret-color: #E53935; /* 匹配主题色 */
  margin-bottom: 80rpx;
  outline: none;
  resize: none;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.02);
}
.form-textarea::placeholder {
  color: #9ca3af;
  font-size: 26rpx;
  line-height: 1.6;
}
.form-textarea:focus {
  border-color: #E53935 !important; /* 匹配主题色 */
  box-shadow: 0 0 0 4rpx rgba(229, 57, 53, 0.1) !important;
  transition: all 0.2s ease;
}
.form-textarea[disabled] {
  background-color: #f9fafb;
  color: #d1d5db;
  border-color: #f3f4f6;
  cursor: not-allowed;
}
.form-textarea::-webkit-scrollbar {
  width: 6rpx;
  height: 6rpx;
}
.form-textarea::-webkit-scrollbar-thumb {
  background-color: #FCE4E4; /* 匹配主题色 */
  border-radius: 3rpx;
}
.form-textarea::-webkit-scrollbar-track {
  background-color: #f9fafb;
}
/* ================= 上传区域样式（优化，匹配主题色） ================= */
.upload-box {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 10rpx 0;
}
.file-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.file-item {
  position: relative;
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #FFFBFB; /* 匹配主题色 */
  border: 1rpx solid #FCE4E4; /* 新增边框，匹配主题 */
}
.media-preview {
  width: 100%;
  height: 100%;
  position: relative;
}
.file-img {
  width: 100%;
  height: 100%;
}
.video-duration {
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
  padding: 4rpx 8rpx;
  background-color: rgba(229, 57, 53, 0.7); /* 匹配主题色 */
  color: #fff;
  font-size: 22rpx;
  border-radius: 4rpx;
}
.file-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 60rpx;
  z-index: 1;
}
.file-icon.video, .file-icon.audio {
  color: #fff;
  text-shadow: 0 0 10rpx rgba(229, 57, 53, 0.5); /* 匹配主题色 */
}
.file-icon.file {
  color: #E53935; /* 匹配主题色 */
}
.file-preview {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  box-sizing: border-box;
}
.file-info {
  margin-top: 20rpx;
  text-align: center;
  width: 100%;
}
.file-name {
  font-size: 24rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.file-size {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}
.del-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background-color: rgba(229, 57, 53, 0.7); /* 匹配主题色 */
  color: #fff;
  font-size: 32rpx;
  border-radius: 50%;
  transform: rotate(0);
  transition: all 0.2s ease;
  z-index: 2;
}
.del-btn:active {
  transform: rotate(90deg);
  background-color: rgba(229, 57, 53, 0.9); /* 匹配主题色 */
}
.upload-status {
  position: absolute;
  bottom: 10rpx;
  left: 10rpx;
  padding: 4rpx 8rpx;
  background-color: rgba(229, 57, 53, 0.7); /* 匹配主题色 */
  color: #fff;
  font-size: 22rpx;
  border-radius: 4rpx;
}
.upload-status.success {
  background-color: rgba(0, 180, 0, 0.8);
  padding: 4rpx 10rpx;
}
.upload-status.fail {
  background-color: rgba(229, 57, 53, 0.9); /* 匹配主题色 */
  padding: 4rpx 10rpx;
}
.upload-btn {
  width: 210rpx;
  height: 210rpx;
  border: 2rpx dashed #FCE4E4; /* 匹配主题色 */
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #FFFBFB; /* 匹配主题色 */
  transition: all 0.2s ease;
}
.upload-btn:active {
  background-color: #FFF0F0; /* 匹配主题色 */
  border-color: #E53935; /* 匹配主题色 */
}
.upload-icon {
  font-size: 60rpx;
  color: #E53935; /* 匹配主题色 */
  margin-bottom: 10rpx;
}
.upload-text {
  font-size: 24rpx;
  color: #E53935; /* 匹配主题色 */
  opacity: 0.8;
}
/* ================= 底部按钮区（优化版） ================= */
.page__ft {
  padding: 24rpx 24rpx 32rpx;
  background-color: #FFFFFF;
  box-shadow: 0 -2rpx 20rpx rgba(229, 57, 53, 0.04);
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  position: relative;
  z-index: 9;
}
.submit-btn {
  width: 100%;
  height: 104rpx;
  line-height: 104rpx;
  background: linear-gradient(135deg, #E53935 0%, #C62828 90%);
  color: #FFFFFF;
  border: none;
  border-radius: 52rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(229, 57, 53, 0.15);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  letter-spacing: 1rpx;
  border: none;
}
.submit-btn::before {
  content: "✓";
  font-size: 28rpx;
  transform: scale(0.9);
}
.submit-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(229, 57, 53, 0.12);
}
.submit-btn::after {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, rgba(255,255,255,0.08), rgba(255,255,255,0.2), rgba(255,255,255,0.08));
  transition: left 0.8s ease;
  width: 50%;
}
.submit-btn:hover::after {
  left: 150%;
}
.submit-btn[disabled] {
  background: linear-gradient(135deg, #E0E0E0 0%, #BDBDBD 100%);
  box-shadow: none;
  color: #8D8D8D;
}
.submit-btn[disabled]::after {
  display: none;
}
/* ================= 响应式适配（优化版） ================= */
@media (max-width: 320rpx) {
  .form-card {
    padding: 40rpx 24rpx;
  }
  .edit-form-item {
    padding: 24rpx 16rpx;
    border-radius: 20rpx;
  }
  .submit-btn {
    height: 96rpx;
    line-height: 96rpx;
    font-size: 30rpx;
  }
  .form-label {
    font-size: 26rpx;
  }
  .form-label-wrap {
    padding: 6rpx 12rpx;
  }
}
/* ================= 补充优化：全局滚动条样式 ================= */
::-webkit-scrollbar {
  width: 4rpx;
  height: 4rpx;
}
::-webkit-scrollbar-track {
  background: #FFF5F5;
  border-radius: 2rpx;
}
::-webkit-scrollbar-thumb {
  background: #FCE4E4;
  border-radius: 2rpx;
}
::-webkit-scrollbar-thumb:hover {
  background: #E53935;
}
/* ================= 输入框核心样式（form-input） ================= */
/* 基础样式（适配普通文本/密码框）- 主流轻量风格 */
.form-input {
  width: 100% !important;
  height: 88rpx !important; /* 主流舒适高度，提升触控体验 */
  line-height: 88rpx !important;
  padding: 0 24rpx !important; /* 更宽松的内边距，输入更舒适 */
  border: 1rpx solid #E5E7EB !important; /* 极浅灰边框，更现代 */
  border-radius: 16rpx !important; /* 大圆角，主流设计趋势 */
  font-size: 30rpx !important; /* 略大字体，提升可读性 */
  color: #111827 !important; /* 中性深灰，比纯黑更柔和 */
  background-color: #FFFFFF !important;
  box-sizing: border-box !important;
  outline: none !important;
  -webkit-appearance: none !important;
  appearance: none !important;
  /* 微阴影，增加层次感 */
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.02) !important;
  /* 过渡动画，交互更丝滑 */
  transition: all 0.2s ease-in-out !important;
}
/* 聚焦状态 - 强反馈但不刺眼 */
.form-input:focus {
  border-color: #3B82F6 !important; /* 主流品牌蓝，更清新 */
  background-color: #F9FAFB !important; /* 极浅灰背景，区分聚焦 */
  /* 轻量级发光效果，现代感 */
  box-shadow: 0 0 0 4rpx rgba(59, 130, 246, 0.1) !important;
  /* 轻微上浮，增强交互感 */
  transform: translateY(-1rpx) !important;
}
/* 禁用状态 - 更自然的灰化效果 */
.form-input:disabled {
  border-color: #F3F4F6 !important;
  color: #9CA3AF !important;
  background-color: #F9FAFB !important;
  cursor: not-allowed !important;
  opacity: 0.85 !important; /* 透明度降低，视觉上区分禁用 */
}
/* 占位符样式 - 更柔和的浅灰 */
.form-input::placeholder {
  color: #D1D5DB !important;
  font-size: 28rpx !important;
  /* 占位符斜体，轻微区分输入内容 */
  font-style: normal !important;
  opacity: 0.8 !important;
}
/* 密码框适配 - 优化圆点显示 */
.form-input[type="password"] {
  letter-spacing: 4rpx !important; /* 更大间距，密码圆点更清晰 */
}
/* 可选：输入框hover效果（针对非小程序端兼容，小程序可保留） */
.form-input:hover:not(:disabled):not(:focus) {
  border-color: #D1D5DB !important;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.03) !important;
}
/* 可选：错误状态样式（扩展用，可根据业务添加） */
.form-input.error {
  border-color: #EF4444 !important;
  box-shadow: 0 0 0 4rpx rgba(239, 68, 68, 0.1) !important;
}

  border-radius: 4rpx;
}
.upload-status.success {
  background-color: rgba(0, 180, 0, 0.8);
  padding: 4rpx 10rpx;
}
.upload-status.fail {
  background-color: rgba(255, 0, 0, 0.8);
  padding: 4rpx 10rpx;
}
/* 上传按钮 */
.upload-btn {
  width: 210rpx;
  height: 210rpx;
  border: 2rpx dashed #d1d5db;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fff;
  transition: all 0.2s ease;
}
.upload-btn:active {
  background-color: #f3f4f6;
  border-color: #00cccc;
}
.upload-icon {
  font-size: 60rpx;
  color: #9ca3af;
  margin-bottom: 10rpx;
}
.upload-text {
  font-size: 24rpx;
  color: #9ca3af;
}
/* 按钮组：拼多多风格 - 全屏宽度 + 合理留白 + 左对齐 */
.btn-group {
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx; /* 拼多多选项按钮标准间距 */
  width: 100%; 
  padding: 0 10rpx; /* 拼多多表单常规左右留白 */
  box-sizing: border-box;
  margin-bottom: 20rpx;
}
/* 商品类型按钮：拼多多核心样式 - 一行4个自适应 + 适中圆角 */
.type-btn {
  height: 76rpx; /* 拼多多选项按钮标准高度 */
  line-height: 76rpx;
  padding: 0 10rpx; /* 内边距适配文字展示 */
  font-size: 26rpx; /* 拼多多易读字体大小 */
  text-align: center;
  border-radius: 8rpx; /* 拼多多选项按钮小圆角（非全圆角） */
  border: 1rpx solid #e0e0e0; /* 默认浅灰边框 */
  background-color: #fff;
  color: #333;
  box-sizing: border-box;
  transition: all 0.2s ease;
  min-width:100rpx;
}
/* 选中态：拼多多经典样式 - 红边框+红文字+浅红背景 */
.type-btn-active {
  border-color: #e64340; /* 拼多多红 */
  color: #e64340;
  background-color: rgba(230, 67, 64, 0.05); /* 浅红背景，不刺眼 */
}
/* 点击态：拼多多交互反馈 */
.type-btn:active {
  background-color: #f9f9f9;
}
/* 更多/收起按钮：拼多多风格 - 和选项按钮视觉统一 */
.more-btn {
  flex: 0 0 calc(25% - 9rpx); /* 和类型按钮同宽度 */
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 10rpx;
  font-size: 26rpx;
  text-align: center;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
  background-color: #f8f8f8; /* 拼多多更多按钮浅灰背景 */
  color: #666;
  box-sizing: border-box;
  transition: all 0.2s ease;
}
/* 更多按钮点击态 */
.more-btn:active {
  background-color: #f0f0f0;
}
/* 重置微信小程序button默认样式（拼多多无默认边框/阴影） */
button {
  margin: 0; /* 清除默认margin */
}
button::after {
  border: none !important; /* 清除小程序button默认伪元素边框 */
}
/* 适配极端情况：当按钮文字过长时，自动省略 */
.type-btn, .more-btn {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}



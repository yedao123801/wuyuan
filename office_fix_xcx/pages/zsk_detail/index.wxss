/* pages/goodsDetail/goodsDetail.wxss */
/* 核心：拼多多风格变量体系 - 高饱和红为主调，白底高对比 */
page {
  padding-bottom: 120rpx !important; 
  background-color: #f5f5f5; /* 拼多多经典浅灰背景 */
  /* 全局变量定义 - 拼多多风格 */
  --primary: #e64340;          /* 拼多多红（主色） */
  --primary-light: #fdf2f2;    /* 拼多多浅红背景 */
  --primary-gradient: linear-gradient(135deg, var(--primary), #d43734);
  --bg-main: #f5f5f5;          /* 页面主背景 */
  --bg-card: #ffffff;          /* 卡片背景（纯白） */
  --bg-light: #f8f8f8;         /* 浅背景（浅灰） */
  --text-black: #333333;       /* 主文字色（深灰） */
  --text-gray: #666666;        /* 次要文字色（中灰） */
  --text-light: #999999;       /* 辅助文字色（浅灰） */
  --border-base: #e5e5e5;      /* 基础边框（浅灰） */
  --radius: 8rpx;              /* 拼多多小圆角 */
  --shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05); /* 轻量阴影 */
}
/* 媒体区域 - 拼多多风格 */
.goods-media {
  width: 100%;
  height: 600rpx;
  background: var(--bg-card);
  border-radius: var(--radius);
  margin-bottom: 10rpx;
  border: none; /* 拼多多无卡片边框 */
}
.video-wrap {
  width: 100%;
  height: 100%;
}
.goods-video {
  width: 100%;
  height: 100%;
}
.swiper-img {
  width: 100%;
  height: 100%;
  border-radius: var(--radius);
}
/* 商品信息区 - 拼多多风格 */
.goods-info {
  padding: 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius);
  border: none; /* 去除边框 */
  margin-bottom: 10rpx;
  box-shadow: var(--shadow); /* 轻量阴影 */
}
.title-wrap {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10rpx;
}
.goods-title {
  font-size: 32rpx;
  color: var(--text-black); /* 拼多多主文字为深灰 */
  line-height: 48rpx;
  flex: 1;
  margin-right: 20rpx;
  font-weight: 500;
}
.goods-opt-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.goods-like-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80rpx;
}
.goods-like-btn .like-icon {
  font-size: 36rpx;
  color: var(--text-gray);
}
/* 点赞选中态 - 拼多多红 */
.goods-like-btn .like-icon.liked {
  color: var(--primary);
}
.goods-like-btn .like-num {
  font-size: 22rpx;
  color: var(--text-gray);
  margin-top: 4rpx;
}
.collect-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80rpx;
}
.collect-icon {
  font-size: 36rpx;
  color: var(--text-gray);
}
/* 收藏选中态 - 拼多多红 */
.collect-icon.collected {
  color: var(--primary);
}
.collect-text {
  font-size: 22rpx;
  color: var(--text-gray);
  margin-top: 4rpx;
}
/* 商家信息样式 - 拼多多风格 */
.merchant-info {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-top: 1rpx solid var(--border-base);
  border-bottom: 1rpx solid var(--border-base);
  margin: 16rpx 0;
}
.merchant-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx; /* 拼多多头像为圆角矩形 */
  margin-right: 16rpx;
  border: none;
}
.merchant-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.merchant-name {
  font-size: 28rpx;
  color: var(--text-black);
  font-weight: 500;
  margin-bottom: 4rpx;
}
.merchant-tag {
  font-size: 22rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  width: fit-content;
  border: none;
}
.enter-icon {
  font-size: 24rpx;
  color: var(--text-gray);
}
/* 价格区域 - 拼多多核心风格 */
.price-area {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
}
.price-label {
  font-size: 24rpx;
  color: var(--text-gray);
  margin-right: 8rpx;
}
/* 价格改为拼多多红 */
.current-price {
  font-size: 40rpx;
  color: var(--primary);
  font-weight: bold;
  margin-right: 16rpx;
}
.original-price {
  font-size: 24rpx;
  color: var(--text-light);
  text-decoration: line-through;
  margin-right: 16rpx;
}
.sales {
  font-size: 24rpx;
  color: var(--text-gray);
}
/* 促销标签 - 拼多多风格 */
.promotion-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 10rpx;
}
.tag {
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
}
/* 红色标签改为拼多多红 */
.tag-red {
  background: var(--primary);
  color: #ffffff;
  border: none;
}
.tag-gray {
  background: var(--bg-light);
  color: var(--text-gray);
  border: none;
}
/* 商品基础信息栏 - 拼多多风格 */
.goods-base-info {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid var(--border-base);
}
.base-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}
.base-label {
  color: var(--text-gray);
  min-width: 120rpx;
}
.base-value {
  color: var(--text-black);
  font-weight: 500;
}
/* 商品简述 - 拼多多风格 */
.goods-brief {
  padding: 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius);
  border: none;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
  box-shadow: var(--shadow);
}
.module-title {
  font-size: 30rpx;
  color: var(--text-black);
  font-weight: bold;
  margin-bottom: 16rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid var(--border-base);
}
.brief-content {
  font-size: 26rpx;
  color: var(--text-gray);
  line-height: 40rpx;
}
/* 机器参数 - 拼多多风格 */
.goods-params {
  padding: 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius);
  border: none;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
  box-shadow: var(--shadow);
}
.params-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.param-item {
  display: flex;
  flex-wrap: wrap;
  font-size: 26rpx;
  line-height: 40rpx;
}
.param-key {
  color: var(--text-gray);
  min-width: 120rpx;
}
.param-value {
  color: var(--text-black);
  flex: 1;
}
/* 规格选择区 - 拼多多风格 */
.spec-area {
  padding: 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius);
  border: none;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
  box-shadow: var(--shadow);
}
.spec-title {
  font-size: 28rpx;
  color: var(--text-black);
  margin-bottom: 16rpx;
  font-weight: 500;
}
.spec-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.spec-item {
  padding: 16rpx 24rpx;
  border: 1rpx solid var(--border-base);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--text-gray);
  background: var(--bg-light);
}
/* 规格选中态 - 拼多多红 */
.spec-active {
  border-color: var(--primary);
  color: var(--primary);
  background: var(--primary-light);
}
/* 数量选择区 - 拼多多风格 */
.num-area {
  padding: 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius);
  border: none;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: var(--shadow);
}
.num-title {
  font-size: 28rpx;
  color: var(--text-black);
  font-weight: 500;
}
.num-input-div {
  display: flex;
  align-items: center;
  height: 80rpx;
  width: 240rpx;
}
.num-input-jian, .num-input-jia {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 36rpx;
  color: var(--text-gray);
  background: var(--bg-light);
  border: 1rpx solid var(--border-base);
  box-sizing: border-box;
  touch-action: manipulation;
}
.num-input-jian {
  border-radius: 8rpx 0 0 8rpx;
}
.num-input-jia {
  border-radius: 0 8rpx 8rpx 0;
}
.num-input-val {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-black);
  border-top: 1rpx solid var(--border-base);
  border-bottom: 1rpx solid var(--border-base);
  box-sizing: border-box;
  background: #ffffff; /* 拼多多数量框为纯白 */
}
.num-input-jian.disabled {
  color: var(--text-light);
  background: #fafafa;
}
.num-input-jian:active, .num-input-jia:active {
  background: var(--primary-light);
  color: var(--primary);
}
/* 富文本详情区 - 拼多多风格 */
.goods-detail {
  padding: 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius);
  border: none;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
  box-shadow: var(--shadow);
}
.detail-title {
  font-size: 30rpx;
  color: var(--text-black);
  font-weight: bold;
  margin-bottom: 20rpx;
  text-align: center;
}
.rich-text-wrap {
  font-size: 26rpx;
  color: var(--text-gray);
  line-height: 40rpx;
}
.rich-text-wrap image {
  width: 100% !important;
  margin: 10rpx 0 !important;
  border-radius: 8rpx;
  border: none;
}
/* 评论区 - 拼多多风格 */
.comment-area {
  padding: 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius);
  border: none;
  margin-top: 10rpx;
  margin-bottom: 0 !important;
  box-shadow: var(--shadow);
}
.comment-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.title-text {
  font-size: 28rpx;
  color: var(--text-black);
  font-weight: bold;
}
.dis-more-btn {
  font-size: 24rpx;
  color: var(--primary);
  padding: 8rpx 12rpx;
}
.comment-list {
  margin-bottom: 30rpx;
}
.comment-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-base);
}
.comment-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  border: none;
}
.nickname {
  font-size: 26rpx;
  color: var(--text-black);
}
.comment-content-wrap {
  margin-bottom: 12rpx;
}
.comment-content {
  font-size: 26rpx;
  color: var(--text-gray);
  line-height: 40rpx;
  display: block;
  margin-bottom: 10rpx;
}
.comment-img-list {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}
.comment-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  border: none;
}
.comment-opt {
  display: flex;
  gap: 20rpx;
  margin-bottom: 12rpx;
}
.like-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.like-icon {
  font-size: 28rpx;
  color: var(--text-gray);
}
.like-icon.liked {
  color: var(--primary);
}
.like-num {
  font-size: 24rpx;
  color: var(--text-gray);
}
.reply-btn {
  display: flex;
  align-items: center;
}
.reply-text {
  font-size: 24rpx;
  color: var(--text-gray);
}
.reply-list {
  margin-left: 72rpx;
  margin-bottom: 12rpx;
}
.reply-item {
  font-size: 24rpx;
  color: var(--text-gray);
  line-height: 36rpx;
  margin-bottom: 8rpx;
}
.reply-nickname {
  color: var(--primary);
}
.reply-input-wrap {
  display: flex;
  gap: 12rpx;
  margin-left: 72rpx;
  margin-top: 12rpx;
}
.reply-input {
  flex: 1;
  height: 60rpx;
  padding: 0 12rpx;
  border: 1rpx solid var(--border-base);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: var(--text-black);
  background: #ffffff;
}
.send-reply-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  background: var(--primary);
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
  padding: 0;
}
/* 发布评论区域 - 拼多多风格 */
.publish-comment {
  display: flex;
  gap: 12rpx;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
  padding-right: 10rpx;
}
.publish-comment .publish-input {
  flex: 1;
  height: 80rpx;
  padding: 12rpx;
  border: 1rpx solid var(--border-base);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: var(--text-black);
  background: #ffffff;
}
.publish-comment .publish-btn {
  width: 120rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--primary);
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
  padding: 0;
}
/* 底部操作栏 - 拼多多风格 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  display: flex;
  background: #ffffff;
  border-top: 1rpx solid var(--border-base);
  z-index: 999;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.cart-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f8f8f8;
  color: var(--primary);
  font-size: 24rpx;
}
.cart-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}
/* 预约/聊天按钮 - 拼多多红 */
.book-btn {
  flex: 1.5;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff7a75; /* 拼多多次红 */
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
}
/* 下单按钮 - 拼多多红 */
.buy-btn {
  flex: 1.5;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
}
/* 预约弹窗样式 - 拼多多风格 */
.book-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
  z-index: 1000;
}
.book-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 85%;
  background: #ffffff;
  border-radius: var(--radius);
  z-index: 1001;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}
.modal-header {
  padding: 20rpx;
  border-bottom: 1rpx solid var(--border-base);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.modal-title {
  font-size: 32rpx;
  color: var(--text-black);
  font-weight: bold;
}
.close-btn {
  font-size: 36rpx;
  color: var(--text-gray);
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
}
.modal-body {
  padding: 20rpx;
  flex: 1;
  overflow-y: auto;
}
.book-item {
  margin-bottom: 30rpx;
}
.book-item .label {
  font-size: 28rpx;
  color: var(--text-black);
  display: block;
  margin-bottom: 16rpx;
  font-weight: 500;
}
.book-spec-list {
  flex-wrap: wrap;
}
.book-num-div {
  margin: 0 auto;
}
.date-scroll {
  white-space: nowrap;
  width: 100%;
}
.date-list {
  display: flex;
  gap: 16rpx;
  padding: 10rpx 0;
}
.date-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  border: 1rpx solid var(--border-base);
  border-radius: 8rpx;
  background: #ffffff;
  color: var(--text-gray);
}
.date-item.date-active {
  border-color: var(--primary);
  background: var(--primary-light);
  color: var(--primary);
}
.date-day {
  font-size: 32rpx;
  color: var(--text-black);
  margin-bottom: 8rpx;
}
.date-month {
  font-size: 22rpx;
  color: var(--text-gray);
}
.time-scroll {
  height: 200rpx;
  width: 100%;
  border: 1rpx solid var(--border-base);
  border-radius: 8rpx;
  background: #ffffff;
}
.time-list {
  padding: 10rpx 0;
}
.time-item {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-gray);
  border-bottom: 1rpx solid var(--border-base);
}
.time-item:last-child {
  border-bottom: none;
}
.time-item.time-active {
  color: var(--primary);
  background: var(--primary-light);
}
.book-note {
  width: 100%;
  height: 120rpx;
  padding: 16rpx;
  border: 1rpx solid var(--border-base);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--text-black);
  box-sizing: border-box;
  background: #ffffff;
}
.modal-footer {
  padding: 20rpx;
  border-top: 1rpx solid var(--border-base);
}
.submit-book-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--primary);
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
}
/* ===================== 核心模块样式（拼多多风格） ===================== */
/* 1. 下单表单区域 - order-form */
.order-form {
  background: var(--bg-card);
  border: none;
  margin: 10rpx 0;
  padding: 20rpx 15rpx;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}
.order-form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-black);
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1px solid var(--border-base);
}
.order-form-content {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}
/* 2. 悬浮购物车按钮 - go-cart-btn（拼多多风格） */
.go-cart-btn {
  position: fixed;
  right: 20rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  background: var(--primary);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(230, 67, 64, 0.4);
  z-index: 999;
  transition: all 0.2s;
  border: none;
}
.go-cart-btn:active {
  transform: scale(0.95);
  background: #d43734;
}
.go-cart-btn .go-cart-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}
.go-cart-btn .go-cart-text {
  font-size: 22rpx;
  line-height: 1;
}
/* 3. 商品视频 - detail-video-url */
.detail-video-url {
  width: 100%;
  height: 400rpx;
  border-radius: var(--radius);
  margin: 10rpx 0;
  background: var(--bg-light);
  border: none;
}
/* 4. 商品音频 - detail-audio-url */
.detail-audio-url {
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  margin: 10rpx 0;
  background: var(--bg-light);
  border: none;
}
/* 5. 发布评论区域 - publish-comment */
.publish-comment {
  display: flex;
  align-items: center;
  gap: 15rpx;
  background: var(--bg-card);
  border: none;
  padding: 15rpx;
  border-radius: var(--radius);
  margin: 10rpx 0;
  box-shadow: var(--shadow);
}
.publish-comment .publish-input {
  flex: 1;
  height: 80rpx;
  line-height: 40rpx;
  padding: 0 20rpx;
  border: 1rpx solid var(--border-base);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: var(--text-black);
  background: #ffffff;
}
.publish-comment .publish-btn {
  width: 160rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: var(--primary);
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  padding: 0;
}
.publish-comment .publish-btn:active {
  background: #d43734;
}
/* 6. 猜你喜欢模块 - other-list */
.other-list {
  background: var(--bg-card);
  border: none;
  margin: 10rpx 0;
  padding: 20rpx 15rpx;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}
.another-list-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-black);
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1px solid var(--border-base);
  position: relative;
}
/* 拼多多风格标题下划线（纯红） */
.another-list-title::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: 0;
  width: 60rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
}
/* 猜你喜欢列表 - 2列网格布局 */
.mt-merchant-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15rpx;
}
/* 猜你喜欢卡片 - 拼多多风格 */
.mt-merchant-card {
  background: #ffffff;
  border: 1px solid var(--border-base);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: none; /* 拼多多卡片无阴影 */
  padding: 10rpx;
}
/* 卡片图片 */
.mt-merchant-img {
  width: 100%;
  height: 200rpx;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
  border: none;
}
/* 卡片信息 */
.mt-merchant-info {
  padding: 0 5rpx;
  background: transparent !important;
}
.mt-merchant-name {
  font-size: 26rpx;
  color: var(--text-black);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
  line-height: 1.4;
}
.mt-merchant-tag {
  font-size: 22rpx;
  color: var(--text-gray);
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  gap: 5rpx;
}
.mt-tag-sep {
  color: var(--border-base);
}
/* 拼多多红色价格 */
.mt-merchant-price {
  margin-bottom: 8rpx;
}
.mt-price {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}
/* 无数据样式 */
.mt-empty {
  grid-column: 1 / 3;
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: var(--text-gray);
  background: transparent !important;
}
/* 商品主图容器 */
.goods-media {
  width: 100%;
  background: #ffffff;
  border-radius: var(--radius);
  overflow: hidden;
  margin: 0 auto 10rpx;
  border: none;
}
/* 商品主图 - swiper-img */
.swiper-img {
  width: 100%;
  display: block;
  border-radius: var(--radius);
  padding: 0;
  margin: 0;
}
/* 详情图片 */
.detail-imgs-url {
  width: 100%;
  margin: 8rpx 0;
  border-radius: var(--radius);
  background-color: #ffffff;
  vertical-align: middle;
  display: inline-block;
  overflow: visible;
  border: none;
}
/* 数量选择框整体样式 - 拼多多风格 */
.num-input {
  margin-bottom: 8rpx;
  font-size: 28rpx;
  color: var(--text-black);
  font-weight: 500;
}
/* 数量操作区域容器 */
.num-input-div {
  display: flex;
  align-items: center;
  height: 80rpx;
  width: 240rpx;
}
/* 减号按钮样式 */
.num-input-jian {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 36rpx;
  color: var(--text-gray);
  background-color: #f8f8f8;
  border: 1rpx solid var(--border-base);
  border-radius: 8rpx 0 0 8rpx;
  box-sizing: border-box;
  touch-action: manipulation;
}
/* 数量数值显示区域 */
.num-input-val {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-black);
  border-top: 1rpx solid var(--border-base);
  border-bottom: 1rpx solid var(--border-base);
  box-sizing: border-box;
  background-color: #ffffff;
}
/* 加号按钮样式 */
.num-input-jia {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 36rpx;
  color: var(--text-gray);
  background-color: #f8f8f8;
  border: 1rpx solid var(--border-base);
  border-radius: 0 8rpx 8rpx 0;
  box-sizing: border-box;
  touch-action: manipulation;
}
/* 按钮点击态（拼多多红） */
.num-input-jian:active, .num-input-jia:active {
  background-color: var(--primary-light);
  color: var(--primary);
}
/* 禁用状态 */
.num-input-jian.disabled {
  color: var(--text-light);
  background-color: #fafafa;
}
/* ================= 输入框核心样式（form-input）- 拼多多风格 ================= */
.form-input {
  width: 100% !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  padding: 0 24rpx !important;
  border: 1rpx solid var(--border-base) !important;
  border-radius: 8rpx !important; /* 拼多多小圆角 */
  font-size: 30rpx !important;
  color: var(--text-black) !important;
  background-color: #ffffff !important;
  box-sizing: border-box !important;
  outline: none !important;
  -webkit-appearance: none !important;
  appearance: none !important;
  box-shadow: none !important; /* 拼多多无阴影 */
  transition: all 0.2s ease-in-out !important;
}
/* 聚焦状态 - 拼多多红边框 */
.form-input:focus {
  border-color: var(--primary) !important;
  background-color: #ffffff !important;
  box-shadow: 0 0 0 4rpx var(--primary-light) !important;
  transform: none !important; /* 取消上浮 */
}
/* 禁用状态 */
.form-input:disabled {
  border-color: #f3f4f6 !important;
  color: var(--text-light) !important;
  background-color: #f9fafb !important;
  cursor: not-allowed !important;
  opacity: 0.85 !important;
}
/* 占位符样式 */
.form-input::placeholder {
  color: var(--text-light) !important;
  font-size: 28rpx !important;
  font-style: normal !important;
  opacity: 0.8 !important;
}
/* 密码框适配 */
.form-input[type="password"] {
  letter-spacing: 4rpx !important;
}
/* hover效果 */
.form-input:hover:not(:disabled):not(:focus) {
  border-color: var(--border-base) !important;
  box-shadow: none !important;
}
/* 错误状态样式 */
.form-input.error {
  border-color: var(--primary) !important;
  box-shadow: 0 0 0 4rpx var(--primary-light) !important;
}
/* 上传区域 - 拼多多风格 */
.upload-box {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 10rpx 0;
}
.file-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.file-item {
  position: relative;
  width: 210rpx;
  height: 210rpx;
  border-radius: 8rpx; /* 拼多多小圆角 */
  overflow: hidden;
  background-color: #f8f8f8;
  border: 1rpx solid var(--border-base);
}
.media-preview {
  width: 100%;
  height: 100%;
  position: relative;
}
.file-img {
  width: 100%;
  height: 100%;
}
.video-duration {
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
  padding: 4rpx 8rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 22rpx;
  border-radius: 4rpx;
}
.file-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 60rpx;
  z-index: 1;
}
.file-icon.video, .file-icon.audio {
  color: #fff;
  text-shadow: 0 0 10rpx rgba(0,0,0,0.5);
}
.file-icon.file {
  color: var(--text-gray);
}
.file-preview {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  box-sizing: border-box;
}
.file-info {
  margin-top: 20rpx;
  text-align: center;
  width: 100%;
}
.file-name {
  font-size: 24rpx;
  color: var(--text-black);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.file-size {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}
.del-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 32rpx;
  border-radius: 50%;
  transform: rotate(0);
  transition: all 0.2s ease;
  z-index: 2;
}
.del-btn:active {
  transform: rotate(90deg);
  background-color: var(--primary);
}
.upload-status {
  position: absolute;
  bottom: 10rpx;
  left: 10rpx;
  padding: 4rpx 8rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 22rpx;
  border-radius: 4rpx;
}
.upload-status.success {
  background-color: #00c800;
  padding: 4rpx 10rpx;
}
.upload-status.fail {
  background-color: var(--primary);
  padding: 4rpx 10rpx;
}
.upload-btn {
  width: 210rpx;
  height: 210rpx;
  border: 2rpx dashed var(--border-base);
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  transition: all 0.2s ease;
}
.upload-btn:active {
  background-color: #f8f8f8;
  border-color: var(--primary);
}
.upload-icon {
  font-size: 60rpx;
  color: var(--text-light);
  margin-bottom: 10rpx;
}
.upload-text {
  font-size: 24rpx;
  color: var(--text-light);
}
/* 按钮组：拼多多核心风格 */
.btn-group {
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx;
  width: 100%;
  padding: 0 10rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}
.type-btn {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 10rpx;
  font-size: 26rpx;
  text-align: center;
  border-radius: 8rpx;
  border: 1rpx solid var(--border-base);
  background-color: #ffffff;
  color: var(--text-black);
  box-sizing: border-box;
  transition: all 0.2s ease;
  min-width:100rpx;
}
.type-btn-active {
  border-color: var(--primary);
  color: var(--primary);
  background-color: var(--primary-light);
}
.type-btn:active {
  background-color: #f8f8f8;
}
.more-btn {
  flex: 0 0 calc(25% - 9rpx);
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 10rpx;
  font-size: 26rpx;
  text-align: center;
  border-radius: 8rpx;
  border: 1rpx solid var(--border-base);
  background-color: #f8f8f8;
  color: var(--text-gray);
  box-sizing: border-box;
  transition: all 0.2s ease;
}
.more-btn:active {
  background-color: #f0f0f0;
}
button {
  margin: 0;
}
button::after {
  border: none !important;
}
.type-btn, .more-btn {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
/* 多行文本框核心样式 - 拼多多风格 */
.form-textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--border-base);
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-black);
  background-color: #ffffff;
  caret-color: var(--primary);
  margin-bottom: 80rpx;
  outline: none;
  resize: none;
}
.form-textarea::placeholder {
  color: var(--text-light);
  font-size: 26rpx;
  line-height: 1.6;
}
.form-textarea:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx var(--primary-light);
  transition: all 0.2s ease;
}
.form-textarea[disabled] {
  background-color: #f9fafb;
  color: var(--text-light);
  border-color: #f3f4f6;
  cursor: not-allowed;
}
.form-textarea::-webkit-scrollbar {
  width: 6rpx;
  height: 6rpx;
}
.form-textarea::-webkit-scrollbar-thumb {
  background-color: var(--border-base);
  border-radius: 3rpx;
}
.form-textarea::-webkit-scrollbar-track {
  background-color: #f9fafb;
}



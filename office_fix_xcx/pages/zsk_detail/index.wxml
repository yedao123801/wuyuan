<view style="padding:20px;">
	<scroll-view scroll-y  enable-back-to-top>
		<!-- 商品核心信息区 -->
		<view class="goods-info">
			<view class="title-wrap">
				<view class="goods-title">{{detail.zsk.title!=null?detail.zsk.title:''}}</view>
				<view class="goods-opt-wrap">
				</view>
			</view>
			<view class="price-area">
				<text class="sales">{{detail.zsk.subtitle!=null?detail.zsk.subtitle:''}}</text>
			</view>
			<view class="promotion-tags">
			</view>
			<view class="goods-base-info">
				<view class="base-item">
					<text class="base-value">{{detail.zsk.fbTime!=null?detail.zsk.fbTime:''}}</text>
				</view>
			</view>
		</view>
		<view class="goods-detail">
			<view class="detail-title">知识内容</view>
			<rich-text nodes="{{detail.zsk.zsContent!=null?detail.zsk.zsContent:''}}" class="rich-text-wrap"></rich-text>
		</view>
	</scroll-view>
</view>
<!-- 底部固定操作栏 -->
<view class="bottom-bar">
</view>
